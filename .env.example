# ============================================================
# WiFi-Pay - пример конфига окружения
# Скопируй в .env и заполни реальными значениями
# ============================================================

# --- MikroTik Роутеры ---
ROUTER_USER=admin
ROUTER_PASS=your_mikrotik_password_here

# --- FreedomPay (ОБЯЗАТЕЛЬНО) ---
MERCHANT_ID=your_merchant_id
SECRET_KEY=your_freedompay_secret_key
# PAY_URL=https://api.freedompay.kz/payment.php

# --- Kaspi Bank ---
KASPI_ENABLED=false
# KASPI_API_BASE_URL=https://kaspi-api.example.kz
# KASPI_API_TOKEN=your_kaspi_api_token
# KASPI_CHECKPAY_TOKEN=your_secret_for_check_pay_callbacks

# --- Безопасность ---
ADMIN_TOKEN=your_strong_admin_token_here

# --- QR-коды ---
QR_TOKEN_TTL_SECONDS=2592000

# --- Тюнинг ---
# PENDING_ACTIVATION_MAX_ATTEMPTS=5
# PENDING_ACTIVATION_RETRY_DELAY_SECONDS=20
# KASPI_SYNC_INTERVAL_SECONDS=30
# KASPI_MATCH_WINDOW_MINUTES=720
# QR_FALLBACK_MAX_IDLE_SECONDS=15
