# Конфигурация приложения
APP_ENV=production
APP_DEBUG=false

# MikroTik роутеры
# Формат: router_id:ip:user:password
# Пример: ROUTER_astana_01=10.0.0.2:admin:your_password
ROUTER_astana_01=10.0.0.2:admin:your_password_here

# FreedomPay настройки
# Можно использовать либо MERCHANT_ID/SECRET_KEY/PAY_URL, либо FREEDOMPAY_*
MERCHANT_ID=your_freedompay_merchant_id
SECRET_KEY=your_freedompay_secret_key
PAY_URL=https://api.freedompay.kz/payment.php
FREEDOMPAY_MERCHANT_ID=your_freedompay_merchant_id
FREEDOMPAY_SECRET_KEY=your_freedompay_secret_key
FREEDOMPAY_API_URL=https://api.freedompay.kz/payment.php

# Kaspi настройки
KASPI_ENABLED=false
KASPI_API_BASE_URL=https://example.kaspi.api
KASPI_API_TOKEN=replace_with_secure_token
KASPI_ORDERS_PATH=/orders
KASPI_ORDER_DETAILS_PATH=/orders/{order_id}
KASPI_API_TIMEOUT_SECONDS=10
KASPI_SYNC_INTERVAL_SECONDS=30
KASPI_MATCH_WINDOW_MINUTES=720
KASPI_PAID_STATUSES=PAID,SUCCESS,DONE
KASPI_FAILED_STATUSES=CANCELLED,CANCELED,FAILED,REJECTED
KASPI_PENDING_STATUSES=NEW,CREATED,PENDING,PROCESSING,WAITING
KASPI_ACTIVATION_RETRY_DELAY_SECONDS=60
KASPI_MAX_ACTIVATION_RETRIES=5

# Timezone
TIMEZONE=Asia/Almaty

# Результативные URL (для callback от банка)
RESULT_URL=https://wifi-pay.kz/payment_result
SUCCESS_URL=https://wifi-pay.kz/success
